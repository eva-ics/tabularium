[server]
listen = "127.0.0.1:3050"
# For systemd (see systemd/tabularium-server.service), install as e.g. /etc/tabularium/config.toml
# and run: tabularium-server --config /etc/tabularium/config.toml (the unit uses absolute paths; no WorkingDirectory).
database_path = "./data/tabularium.db"
index_dir = "./data/tabularium.index"
# Tokio worker threads; 0 = use available_parallelism()
workers = 1
# Long-poll `wait` RPC / `?wait=true` max wait (seconds)
timeout = 3600

# Optional MCP (streamable HTTP). Build with: cargo build -p tabularium-server --features mcp
[mcp]
listen = "127.0.0.1:3031"
# WARNING: `full = true` registers destructive MCP tools (delete/move/rename document or directory, reindex).
# Same authentication as JSON-RPC — trusted private / operator-controlled deployments only. Omit or false for safe default.
# full = false
# Optional path to deployment-specific help (read at startup).
# server_help = "/path/to/server_help.md"
