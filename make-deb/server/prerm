#!/bin/sh
set -e
case "$1" in
remove | upgrade | deconfigure)
    if [ -x /bin/systemctl ] && [ -d /run/systemd/system ]; then
        if systemctl is-active --quiet tabularium-server.service 2>/dev/null; then
            touch /run/tabularium-deb-was-active
        else
            rm -f /run/tabularium-deb-was-active
        fi
        systemctl stop tabularium-server.service || true
    fi
    ;;
esac
exit 0
